# ─────────────────────────────────────────────────────────────────────────────
# PRISM Backend — Variables d'environnement
#
# USAGE :
#   cp .env.example .env
#   Renseigner les valeurs dans .env
#   NE JAMAIS committer .env — il est dans .gitignore
# ─────────────────────────────────────────────────────────────────────────────

# ── Provider IA ───────────────────────────────────────────────────────────────
# Valeurs : anthropic | mistral | ollama
AI_PROVIDER=anthropic

# ── Anthropic (Claude) ────────────────────────────────────────────────────────
# Obtenir une clé sur : https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Mistral AI (souveraineté UE 🇫🇷) ─────────────────────────────────────────
# Obtenir une clé sur : https://console.mistral.ai
# Modèles : mistral-large-latest | mistral-small-latest | mistral-nemo | codestral-latest
MISTRAL_API_KEY=...
MISTRAL_MODEL=mistral-large-latest

# ── Ollama (LLM local — air-gap / enterprise) ─────────────────────────────────
# Lancer : ollama serve  (puis : ollama pull mistral-nemo)
# OLLAMA_HOST peut être une IP distante (GPU server sur le réseau interne)
OLLAMA_HOST=localhost
OLLAMA_PORT=11434
OLLAMA_MODEL=mistral-nemo
OLLAMA_TIMEOUT=120

# ── Paramètres IA ─────────────────────────────────────────────────────────────
# Taille max du contexte injecté (knowledge base + .prism/ + SIF)
AI_MAX_CONTEXT_CHARS=40000
