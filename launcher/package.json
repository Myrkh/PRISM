{
  "name": "prism-launcher",
  "version": "1.0.0",
  "description": "PRISM Desktop Launcher",
  "author": "PRISM Engineering",
  "repository": {
    "type": "git",
    "url": "https://github.com/Myrkh/PRISM.git"
  },
  "main": "electron/main.js",
  "private": true,
  "scripts": {
    "dev:vite":     "vite",
    "dev:electron": "wait-on http://localhost:5174 && electron .",
    "dev":          "concurrently \"npm:dev:vite\" \"npm:dev:electron\"",
    "build":        "tsc && vite build",
    "dist":         "npm run build && electron-builder --win",
    "dist:mac":     "npm run build && electron-builder --mac",
    "dist:linux":   "npm run build && electron-builder --linux"
  },
  "dependencies": {
    "bcryptjs":      "^2.4.3",
    "better-sqlite3": "^9.6.0",
    "lucide-react":  "^0.383.0",
    "react":         "^18.3.0",
    "react-dom":     "^18.3.0"
  },
  "devDependencies": {
    "@types/bcryptjs":       "^2.4.6",
    "@types/better-sqlite3": "^7.6.10",
    "@types/react":          "^18.3.0",
    "@types/react-dom":      "^18.3.0",
    "@vitejs/plugin-react":  "^4.3.0",
    "autoprefixer":          "^10.4.19",
    "concurrently":          "^8.2.2",
    "electron":              "^29.0.0",
    "electron-builder":      "^24.13.0",
    "electron-rebuild":      "^3.2.9",
    "postcss":               "^8.4.38",
    "tailwindcss":           "^3.4.4",
    "typescript":            "^5.4.5",
    "vite":                  "^5.3.0",
    "wait-on":               "^7.2.0"
  },
  "build": {
    "appId":       "com.prism.launcher",
    "productName": "PRISM Launcher",
    "directories": { "output": "release" },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "public/**/*",
      "src/assets/**/*"
    ],
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "icon":   "public/logo.png"
    },
    "nsis": {
      "oneClick":              true,
      "perMachine":            false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName":          "PRISM Launcher"
    },
    "mac": {
      "target": [{ "target": "dmg", "arch": ["x64", "arm64"] }],
      "category": "public.app-category.productivity"
    }
  }
}
